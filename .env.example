# OpenAI-compatible endpoint for the planner/model layer.
URL=your-api-url

# API key for the model endpoint above.
KEY=your-api-key

# Windows broker endpoint used in real mode.
# Default runtime fallback is http://127.0.0.1:10578.
WINDOWS_BROKER_ENDPOINT=http://127.0.0.1:10578

# Optional API key for broker auth. Leave empty if broker auth is disabled.
WINDOWS_BROKER_API_KEY=

# Whether real mode may auto-start the broker when health checks fail.
WINDOWS_BROKER_START=true

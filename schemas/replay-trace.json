{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://windows-cua-lab.local/schemas/replay-trace.json",
  "title": "Replay Trace",
  "description": "Persisted run-level trace for a Windows CUA session.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "traceId",
    "sessionId",
    "createdAt",
    "target",
    "artifacts",
    "steps",
    "summary",
    "safetyEvents"
  ],
  "properties": {
    "traceId": {
      "type": "string",
      "minLength": 1
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "app",
        "environment"
      ],
      "properties": {
        "app": {
          "type": "string"
        },
        "environment": {
          "type": "string",
          "enum": [
            "windows-desktop"
          ]
        },
        "operatorPlane": {
          "type": "string",
          "enum": [
            "wsl"
          ]
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "screenshots",
        "actionTrace",
        "verifierTrace",
        "summaryReport"
      ],
      "properties": {
        "screenshots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "actionTrace": {
          "type": "string"
        },
        "verifierTrace": {
          "type": "string"
        },
        "summaryReport": {
          "type": "string"
        }
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "transition-envelope.json"
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "stepCount"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "completed",
            "failed",
            "blocked",
            "partial"
          ]
        },
        "stepCount": {
          "type": "integer",
          "minimum": 0
        },
        "verificationPassed": {
          "type": "boolean"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "safetyEvents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "decision"
        ],
        "properties": {
          "decision": {
            "type": "string",
            "enum": [
              "allowed",
              "blocked",
              "review_required"
            ]
          },
          "reason": {
            "type": "string"
          },
          "transitionId": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "decision": {
                  "enum": [
                    "blocked",
                    "review_required"
                  ]
                }
              }
            },
            "then": {
              "required": [
                "reason"
              ]
            }
          }
        ]
      }
    }
  }
}
